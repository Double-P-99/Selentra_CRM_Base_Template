# ============================================================
# Selentra CRM – Environment Variables Example
# Copy this file to .env and fill in your values.
# ============================================================

# Django
SECRET_KEY=your-very-secret-key-change-this
DJANGO_SETTINGS_MODULE=config.settings.development

# Allowed hosts (comma separated, e.g. mycrm.com,www.mycrm.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Time zone (e.g. America/Mexico_City, America/New_York)
TIME_ZONE=UTC

# Database (SQLite for dev, PostgreSQL for production)
DB_NAME=selentra_crm
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis (production cache/sessions)
REDIS_URL=redis://localhost:6379/1

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@yourcompany.com

# Security (set to True in production)
SECURE_SSL_REDIRECT=False

# CRM Branding (customize per client)
CRM_COMPANY_NAME=Selentra CRM
CRM_COMPANY_LOGO=
CRM_PRIMARY_COLOR=#0d6efd
CRM_SUPPORT_EMAIL=support@yourcompany.com
